<!DOCTYPE html>
<html lang="en">
  <!-- Head -->
  <%- include('../partials/head.ejs') %>
  <body>
    <!-- Header -->
    <%- include('../partials/header.ejs') %>

    <!-- Main content-->
    <main class="main">
      <!-- Show errors -->
      <% if(locals.errors) { %>
        <%- include('../partials/errors.ejs') %>
      <% }  %>

      <div>
        <form action="<%= locals.folderId ? `/folders/${folderId}/files/upload` : `/files/upload` %>" method="post" enctype="multipart/form-data" novalidate>
          <div class="form__control">
            <label for="fileUpload">Select files to upload (Allowed file types: images, audio & video files, .doc & .docx files, and .pdf) (Max size allowed per file: 20 MB) (Max number of files can be uploaded at a time: 5)</label>
            <!-- Many mobile devices also let the user take a picture with the camera when 'image/*' is used -->
            <input type="file" id="fileUpload" name="fileUpload" accept=".doc, .docx, .pdf, image/*, audio/*, video/*" multiple />
          </div>
          <div class="preview">
            <p>No files currently selected for upload</p>
          </div>
          <div class="errors">
            <ul class="errors__list"></ul>
          </div>
          
          <button class="btn-clear" type="button">Clear</button>
          <button class="btn-submit">Submit</button>
        </form>
        
      </div>
    </main>

    <!-- Footer -->
    <%- include('../partials/footer.ejs') %>

    
  </body>

  <script>
    const fileInput = document.querySelector("#fileUpload");
    
    const errorsList = document.querySelector('.errors__list')
    const preview = document.querySelector(".preview");
    const submitBtn = document.querySelector(".btn-submit")
    const clearBtn = document.querySelector('.btn-clear')


    // fileInput.style.opacity = 0;
    submitBtn.disabled = true
    clearBtn.disabled = true

    
    let currentFilesArr

    const allowedFileTypes = [
      "image/*",
      "audio/*",
      "video/*",
      "application/msword",
      "application/vnd.openxmlformats-officedocument.wordprocessingml.document",
      "application/pdf",
    ];

    function validateFileTypeAndSize() {
      currentFilesArr = [];
      const currentFiles = fileInput.files;
      const maxFileSize = 20 * 1024 * 1024; // 20 MB

      for (const file of currentFiles) {
        const fileType = file.type;
        const fileSize = file.size;

        // Check file size
        if (fileSize > maxFileSize) {
          displayError(file, 'bigFile')
          continue; // Skip to the next file
        }

        // .some() returns true as soon as it finds a match and stops looping
        const isAllowed = allowedFileTypes.some(type => {
          if (type.endsWith('/*')) {
            const prefix = type.split('/')[0];
            return fileType.startsWith(prefix + '/');
          }
          return fileType === type;
        });

        if (isAllowed) {
          currentFilesArr.push(file);
        } else {
          displayError(file, 'wrongType')
        }
      }
    }

    //  Remove files if there are more than 5
    function validateFileListLength() {
      if(currentFilesArr.length > 5) {
        currentFilesArr.splice(5)
        displayError(null, 'tooMany')
      }

      submitBtn.disabled = currentFilesArr.length === 0
    }

    // Display error messages for invalid files
    function displayError(file, errorType) {
      const listItem = document.createElement('li')

      const errorMsgs = {
        'bigFile': `File "${file?.name}" exceeds 20MB limit.`,
        'wrongType': `File "${file?.name}" is not a supported file type.`,
        'tooMany': `Too many files. Only first 5 files were uploaded.`
      }

      listItem.textContent = errorMsgs[errorType] || `Error with ${file.name}`
      errorsList.appendChild(listItem)
    }

    // Update FileList
    function updateFileList() {
      // Use DataTransfer object to modify FileList
      const dt = new DataTransfer();
      currentFilesArr.forEach(file => {
        dt.items.add(file)
      });

      // Update fileInput element directly
      fileInput.files = dt.files; 

      clearBtn.disabled = false
    }


    // Preview files to be uploaded
    function previewFiles() {
      while (preview.firstChild) {
        preview.removeChild(preview.firstChild);
      }

      const list = document.createElement("ol");
      preview.appendChild(list);

      const currentFiles = fileInput.files

      for(const file of currentFiles) {
        const listItem = document.createElement("li");
        const para = document.createElement("p");
        para.textContent = `File name: ${file.name}, 
          File size: ${returnFileSize(file.size,)} (${file.size} bytes).`;

        const fileType = file.type
        const fileURL = URL.createObjectURL(file)
        console.log('file url:', fileURL)

        // Image file
        if(fileType.startsWith('image/')) {
          const image = document.createElement("img");
          image.src = fileURL;
          image.alt = image.title = file.name;
          image.style.width = "50px"
          image.style.height = "50px"

          listItem.appendChild(image);
          listItem.appendChild(para);
        } else if (fileType.startsWith('audio/')) { // Audio file
          // User can listen to the file before uploading
          const audio = document.createElement("audio");
          audio.src = fileURL;
          audio.controls = true; // Shows play/pause and volume buttons
          audio.style.width = "200px";
          
          listItem.appendChild(audio);
          listItem.appendChild(para);
        } else if (fileType.startsWith('video/')) { // Video file
          const video = document.createElement("video")
          video.src = fileURL
          video.style.width = "50px"
          video.style.height = "50px"
          video.currentTime = 1; // Load the first frame as a "preview"

          listItem.appendChild(video);
          listItem.appendChild(para);
        } else if (fileType === 'application/msword' || fileType === 
            'application/vnd.openxmlformats-officedocument.wordprocessingml.document') {
          // Show doc icon
          const icon = document.createElement("div");
          icon.textContent = "📄";
          icon.style.width = "50px"
          icon.style.height = "50px"

          listItem.appendChild(icon);
          listItem.appendChild(para);
        } else if (fileType === 'application/pdf') {
          // Show pdf icon
          const icon = document.createElement("div");
          icon.textContent = "PDF";
          icon.style.width = "50px"
          icon.style.height = "50px"

          listItem.appendChild(icon);
          listItem.appendChild(para);
        }
        list.appendChild(listItem);
      }
    }

    // Calculate file size
    function returnFileSize(number) {
      if (number < 1024) {
        return `${number} bytes`;
      } else if (number >= 1024 && number < 1024 * 1024) {
        return `${(number / 1024).toFixed(2)} KB`;
      }
      return `${(number / (1024 * 1024)).toFixed(2)} MB`;
    }

    fileInput.addEventListener("change", 
      
      () => {
        errorsList.innerHTML = ''
        validateFileTypeAndSize()
        validateFileListLength()
        updateFileList()
        previewFiles()
      }
    );

    clearBtn.addEventListener('click', () => {
      currentFilesArr = []
      updateFileList()
      previewFiles()
      submitBtn.disabled = true
      clearBtn.disabled = true
    })
  </script>
</html>
