<!DOCTYPE html>
<html lang="en">
  <!-- Head -->
  <%- include('../partials/head.ejs') %>
  <body>
    <!-- Header -->
    <%- include('../partials/header.ejs') %>

    <!-- Main content-->
    <main class="main">
      <dialog class="dialog">

        <!-- Show errors -->
        <% if(locals.errors && locals.errors.length > 0) { %>
          <%- include('../partials/errors.ejs') %>
        <% }  %>

        <form class="form" action="/folders/new" method="POST">
          <h2 class="">New Folder</h2>
          <div class="form__control">
            <label class="form__label" for="folderName">Folder Name (required)
              <span>Allowed characters: Letters, numbers, spaces, period, underscore and hyphen</span>
            </label>
            <input
              class="form__input"
              id="folderName"
              name="name"
              placeholder="Name"
              type="text"
              value="<%= locals.folder?.name || '' %>"
              pattern="[a-zA-Z0-9\s._\-]+"
              required
                />
          </div>
          <div class="form__buttons">
            <button class="btn  btn--cancel" type="button">Cancel</button>
            <button class="btn  btn--submit" type="submit">Create</button>
          </div>
        </form>
      </dialog>

      <!-- Show folders -->
      <% if(locals.folders && locals.folders.length > 0) { %>
        <%- include('../partials/folders.ejs') %>
      <% }  %>
      
    </main>

    <!-- Footer -->
    <%- include('../partials/footer.ejs') %>
  </body>
  
  <script>
    const newFolderBtn = document.querySelector('.btn--newFolder')
    const dialog = document.querySelector('.dialog')
    const cancelBtn = document.querySelector('.btn--cancel')
    const errorMsgs = document.querySelectorAll('.errors__msg')

    // Show new folder form
    newFolderBtn.addEventListener('click', () => {
      dialog.showModal()
    })

    // Close new folder form
    cancelBtn.addEventListener('click', () => {
      dialog.close()
    })

    if(errorMsgs.length > 0) {
      dialog.showModal()
    }
   
    
  </script>
</html>
