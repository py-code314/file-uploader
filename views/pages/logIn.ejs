<!DOCTYPE html>
<html lang="en">
  <!-- Head -->
  <%- include('../partials/head.ejs') %>
  <body>
    <!-- Header -->
    <%- include('../partials/header.ejs') %>

    <!-- Main content-->
    <main class="main">
      <div class="wrapper">

       

        <div class="login">
          <h2 class="login__header sub-title">Log In</h2>

          <!-- Show errors -->
          <% if(locals.errors.length > 0) { %>
            <%- include('../partials/errors.ejs') %>
          <% }  %>
        
          <form class="form" action="/logIn" method="POST">
            <div class="form__control">
              <label class="form__label" for="email">Email</label>
              <input
                class="form__input"
                id="email"
                name="email"
                placeholder="Email"
                type="email"
                autocomplete="email"
                value="<%= locals.user?.email || '' %>"
                required
                autofocus
                 />
            </div>

            <div class="form__control">
              <label class="form__label" for="password">Password</label>
              <input
                class="form__input"
                id="password"
                name="password"
                type="password"
                placeholder="Password"
                required
                 />
            </div>
            
            <button class="btn btn--cta btn--form" type="submit">Log In</button>
          </form>
        </div>
      </div>
    </main>

    <!-- Footer -->
    <%- include('../partials/footer.ejs') %>
  </body>
</html>
